{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{"type": "header", "key": "x-forwarded-proto", "value": "http"}],
      "destination": "https://weddingclicks.us/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/send-review-requests",
      "schedule": "0 8 * * *"
    }
  ]
}
